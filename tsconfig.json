{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  },
  "exclude": [
    "./node_modules/**",
    "./dist/**",
    "./build/**",
    "./coverage/**",
    "./.vercel/**",
    "./.vercel_build_output/**",
    "./.svelte/**"
  ]
}